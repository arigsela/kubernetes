# Vault secrets backup - temporary file for reinitialization
vault-secrets-backup.txt

# Recovery directory - contains sensitive credentials
# DO NOT COMMIT - contains Vault unseal keys and secrets
recovery/vault-credentials.txt
recovery/restore-vault-secrets.sh
recovery/full-cluster-recovery.sh

# Keep the documentation but not the sensitive scripts
!recovery/CLUSTER-RECOVERY.md

# AWS credentials
.aws/
**/credentials

# macOS
.DS_Store
**/.DS_Store

# Claude Code local settings (keep skills, ignore local settings)
.claude/settings.local.json
**/.claude/settings.local.json

# gstack local tooling artifacts (browse logs, caches — not repo content)
.gstack/

# git worktrees created by agent tooling (local artifact, never repo content)
.claude/worktrees/

# Python bytecode from the repo's validators/tests (scripts/, tests/) — generated, never repo content
__pycache__/
*.pyc

# Local security audit deliverables — contain credential references and a
# cluster attack-surface map; keep local, never commit to this public repo.
docs/cluster-apps-audit-*.md

# Local architecture-research notes — assess the live setup's security posture
# (auth model, isolation gaps, hardware/CPU weaknesses). Same reasoning as the
# audit docs above: keep local, never commit to this public repo.
docs/research/

# Local reference clone of arigsela/claude-agents (nested git repo, consulted
# read-only for design work) — never tracked here, neither as files nor as a
# submodule gitlink.
docs/reference/claude-agents/
